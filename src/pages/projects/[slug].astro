---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, status, period, tags, builtWith, repo, demo } = project.data;
const { Content } = await render(project);
const tagKinds = ['kw', 'str', 'fn'];
---

<Base title={`${title} — Jayden Phu`} description={summary} ogType="article">
  <div class="page">
    <a class="back-link" href="/#projects">cd ../projects</a>

    <header class="page-head cs-header">
      <span class="path">/// case study</span>
      <h1>{title}</h1>
      <p class="cs-summary">{summary}</p>
      <div class="cs-meta">
        <span class="cs-status"><span class="dot" aria-hidden="true"></span>{status}</span>
        <span>{period}</span>
        {repo && <a href={repo} target="_blank" rel="noopener noreferrer">source ↗</a>}
        {demo && <a href={demo} target="_blank" rel="noopener noreferrer">live demo ↗</a>}
      </div>
      <div class="tags">
        {tags.map((tag, i) => <span class={`tag ${tagKinds[i % tagKinds.length]}`}>{tag}</span>)}
      </div>
    </header>

    <aside class="built-with">
      <h2>// built with</h2>
      <ul>
        {builtWith.map((item) => (
          <li>
            <span class="bw-name">{item.name}</span>
            <span class="bw-note">{item.note}</span>
          </li>
        ))}
      </ul>
    </aside>

    <article class="prose">
      <Content />
    </article>
  </div>
</Base>
