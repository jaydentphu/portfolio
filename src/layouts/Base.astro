---
import { SITE } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}

const { title, description = SITE.description, ogType = 'website' } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">skip to content</a>

    <div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>
    <div class="cursor-ring" id="cursorRing" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursorDot" aria-hidden="true"></div>

    <nav>
      <a class="logo" href="/" aria-label="Jayden Phu — home">
        jayden<span>.dev()</span><span class="caret" aria-hidden="true"></span>
      </a>
      <div class="nav-links">
        <a href="/#projects">projects</a>
        <a href="/#about">about</a>
        <a href="/resume.pdf">resume</a>
      </div>
    </nav>

    <main id="main">
      <slot />
    </main>

    <div class="cs-overlay" id="csOverlay" hidden>
      <div class="cs-overlay-backdrop" id="csOverlayBackdrop"></div>
      <div
        class="cs-overlay-panel"
        id="csOverlayPanel"
        role="dialog"
        aria-modal="true"
        aria-label="Case study"
      >
        <button class="cs-overlay-close" id="csOverlayClose">close [esc]</button>
        <div id="csOverlayContent"></div>
      </div>
    </div>

    <footer id="contact">
      <h2>Let's build something.</h2>
      <p>
        Open to AI engineering internships and interesting collaborations.
        Reach out however's easiest.
      </p>
      <div class="contact-links">
        <a href={`mailto:${SITE.email}`}>email</a>
        <a href={SITE.github} target="_blank" rel="noopener noreferrer">github</a>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer">linkedin</a>
        <a href="/resume.pdf">resume.pdf</a>
      </div>
    </footer>

    <script>
      // ---------- custom cursor (dot + trailing ring + ambient glow) ----------
      const dot = document.getElementById('cursorDot')!;
      const ring = document.getElementById('cursorRing')!;
      const glow = document.getElementById('cursorGlow')!;

      const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (fine) {
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        let ringX = mouseX, ringY = mouseY;
        let glowX = mouseX, glowY = mouseY;

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          dot.style.left = mouseX + 'px';
          dot.style.top = mouseY + 'px';
          if (reduced) {
            ring.style.left = mouseX + 'px';
            ring.style.top = mouseY + 'px';
            glow.style.left = mouseX + 'px';
            glow.style.top = mouseY + 'px';
          }
        });

        const lerp = (a: number, b: number, n: number) => (1 - n) * a + n * b;

        function animateCursor() {
          ringX = lerp(ringX, mouseX, 0.18);
          ringY = lerp(ringY, mouseY, 0.18);
          ring.style.left = ringX + 'px';
          ring.style.top = ringY + 'px';

          glowX = lerp(glowX, mouseX, 0.07);
          glowY = lerp(glowY, mouseY, 0.07);
          glow.style.left = glowX + 'px';
          glow.style.top = glowY + 'px';

          requestAnimationFrame(animateCursor);
        }
        if (!reduced) animateCursor();

        // grow the ring over anything interactive (delegated, works on all pages)
        document.addEventListener('mouseover', (e) => {
          const t = (e.target as Element).closest('a, button, .card, .word, .skill');
          ring.classList.toggle('active', !!t);
        });
      }
    </script>

    <script>
      // ---------- case study overlay ----------
      // Case study links open in an in-page overlay. The full pages still exist
      // (deep links, SEO, no-JS fallback); the URL updates via pushState so
      // back/forward and refresh behave normally.
      const overlay = document.getElementById('csOverlay')!;
      const panel = document.getElementById('csOverlayPanel')!;
      const contentEl = document.getElementById('csOverlayContent')!;
      const backdrop = document.getElementById('csOverlayBackdrop')!;
      const closeBtn = document.getElementById('csOverlayClose')!;

      type Entry = { html: string; title: string };
      const cache = new Map<string, Entry>();
      const baseTitle = document.title;
      const baseUrl = location.pathname;
      let lastFocus: HTMLElement | null = null;
      let isOpen = false;

      async function load(href: string): Promise<Entry | null> {
        const cached = cache.get(href);
        if (cached) return cached;
        try {
          const res = await fetch(href);
          if (!res.ok) return null;
          const doc = new DOMParser().parseFromString(await res.text(), 'text/html');
          const page = doc.querySelector('.page');
          if (!page) return null;
          page.querySelector('.back-link')?.remove();
          const entry = { html: page.innerHTML, title: doc.title };
          cache.set(href, entry);
          return entry;
        } catch {
          return null;
        }
      }

      async function show(href: string, push: boolean) {
        const entry = await load(href);
        if (!entry) {
          window.location.href = href; // graceful fallback: full page
          return;
        }
        contentEl.innerHTML = entry.html;
        document.title = entry.title;
        overlay.hidden = false;
        isOpen = true;
        document.documentElement.style.overflow = 'hidden';
        panel.scrollTop = 0;
        lastFocus = document.activeElement as HTMLElement;
        closeBtn.focus();
        if (push) history.pushState({ caseStudy: href }, '', href);
      }

      function hide() {
        overlay.hidden = true;
        isOpen = false;
        document.documentElement.style.overflow = '';
        document.title = baseTitle;
        lastFocus?.focus();
      }

      document.addEventListener('click', (e) => {
        if (e.defaultPrevented || e.button !== 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const link = (e.target as Element).closest('a');
        if (!link || link.target === '_blank') return;
        const href = link.getAttribute('href') ?? '';
        if (!/^\/projects\/[^/]+\/?$/.test(href)) return;
        const normalized = href.endsWith('/') ? href : href + '/';
        if (location.pathname === normalized) return; // already on the full page
        e.preventDefault();
        show(normalized, true);
      });

      const requestClose = () => {
        if (!isOpen) return;
        if (history.state?.caseStudy) history.back();
        else {
          hide();
          history.replaceState(null, '', baseUrl);
        }
      };
      closeBtn.addEventListener('click', requestClose);
      backdrop.addEventListener('click', requestClose);

      document.addEventListener('keydown', (e) => {
        if (!isOpen) return;
        if (e.key === 'Escape') {
          e.preventDefault();
          requestClose();
        } else if (e.key === 'Tab') {
          // keep focus inside the dialog
          const focusables = panel.querySelectorAll<HTMLElement>(
            'button, a[href], [tabindex]:not([tabindex="-1"])'
          );
          if (focusables.length === 0) return;
          const first = focusables[0];
          const last = focusables[focusables.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });

      window.addEventListener('popstate', (e) => {
        const state = (e.state ?? {}) as { caseStudy?: string };
        if (state.caseStudy) show(state.caseStudy, false);
        else if (isOpen) hide();
      });
    </script>
  </body>
</html>
